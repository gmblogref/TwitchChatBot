{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "TwitchChatBot.UI.Services.EventSubSocketService": "Error"
    }
  },
  "Twitch": {
    "BotUsername": "YOUR_BOT_USERNAME",
    "Channel": "YOUR_CHANNEL_NAME",
    "BotUserId": "YOUR_BOT_USER_ID",
    "BroadcasterUserId": "YOUR_BROADCASTER_USER_ID",
    "TwitchUrl": "https://twitch.tv/"
  },
  "Auth": {
    "BotClientId": "YOUR_APPLICATION_CLIENT_ID",
    "BotClientSecret": "YOUR_APPLICATION_CLIENT_SECRET",
    "TwitchClientId": "YOUR_TWITCH_CLIENT_ID",

    "OAuthToken": "YOUR_OAUTH_TOKEN",
    "OAuthBearerBot": "YOUR_OAUTH_BEARER_TOKEN",
    "AccessToken": "YOUR_USER_ACCESS_TOKEN",
    "AppAccessToken": "YOUR_APP_ACCESS_TOKEN",
    "RefreshToken": "YOUR_REFRESH_TOKEN"
  },
  "Ads": {
    "AdInitialSeconds": 120,
    "AdIntervalMinutes": 60,
    "DefaultUserName": "DEFAULT_USERNAME"
  },
  "WebHost": {
    "BaseUrl": "http://localhost:3000/",
    "WebRoot": "wwwroot"
  },
  "EventSub": {
    "Secret": "YOUR_EVENTSUB_SECRET",
    "CallbackUrl": "https://b2c2-22-33-44-55.ngrok.io/eventsub",
    "Uri": "wss://eventsub.wss.twitch.tv/ws",
    "PostSubscriptionsUrl": "https://api.twitch.tv/helix/eventsub/subscriptions",
    "Validate": "https://id.twitch.tv/oauth2/validate"
  },
  "MediaMapFiles": {
    "TwitchAlertMedia": "PATH_TO_MEDIA_FOLDER/twitchAlertsMediaMap.json",
    "ExcludedUsersMedia": "PATH_TO_MEDIA_FOLDER/excludedUsers.json",
    "FirstChattersMedia": "PATH_TO_MEDIA_FOLDER/firstChatMediaMap.json",
    "CommandAlertMedia": "PATH_TO_MEDIA_FOLDER/commandsMediaMap.json",
    "UserWatchStreakMedia": "PATH_TO_MEDIA_FOLDER/watch_streaks.json"
  },
  "MediaBase": {
    "TwitchAlertsFolder": "YOUR_ALERTS_FOLDER"
  },
  "Chatters": {
    "ModsUrl": "https://api.twitch.tv/helix/moderation/moderators?broadcaster_id={broadcasterId}",
    "VipUrl": "https://api.twitch.tv/helix/channels/vips?broadcaster_id={broadcasterId}",
    "InitialDelay": 60,
    "ContinuousDelay": 300
  },
  "TTS": {
    "Engine": "Polly",
    "PollyRegion": "us-east-1",
    "DefaultSpeaker": "Matthew",
    "MaxChars": 350,
    "AllowedVoices": [
      "Matthew",
      "Joanna",
      "Brian",
      "Emma",
      "Justin",
      "Kimberly",
      "Amy",
      "Russell",
      "Nicole",
      "Olivia",
      "Stephen",
      "Salli",
      "Joey",
      "Ivy",
      "Kendra"
    ],
    "Voices": {
      "Cheer": "YOUR_CHEER_VOICE",
      "Subscribe": "YOUR_SUBSCRIBE_VOICE",
      "SubscriptionMessage": "YOUR_SUB_MESSAGE_VOICE",
      "SingleGiftSub": "YOUR_SINGLE_GIFT_VOICE",
      "GiftSubs": "YOUR_GIFT_BUNDLE_VOICE",
      "Raid": "YOUR_RAID_VOICE",
      "Follow": "YOUR_FOLLOW_VOICE",
      "WatchStreak": "YOUR_STREAK_VOICE",
      "ChannelPoints": "YOUR_CHANNEL_POINTS_VOICE"
    },
    "Templates": {
      "Follow": "{username} has followed the channel.",
      "Raid": "{raider} is raiding with {viewers} viewers.",
      "SingleGiftSub": "{username} gifted a Tier {tier} subscription to {recipient}.",
      "MysteryGift": "{username} gifted {numOfSubs} Tier {tier} subscriptions.",
      "CheerNoMessage": "{username} cheered {bits} bits.",
      "SubNoMessage": "{username} subscribed at Tier {tier}.",
      "ReSub": "{username} resubscribed for {months} months at Tier {tier}.",
      "WatchStreak": "{username} has a watch streak of {streakCount} streams."
    }
  },
  "Commands": {
    "UsersByLogin": "https://api.twitch.tv/helix/users?login={login}",
    "StreamsByUserId": "https://api.twitch.tv/helix/streams?user_id={id}",
    "ChannelInfoByBroadcasterId": "https://api.twitch.tv/helix/channels?broadcaster_id={id}",
    "VideosByUserId": "https://api.twitch.tv/helix/videos?user_id={id}&type=archive&first=1",
    "GamesByGameId": "https://api.twitch.tv/helix/games?id={gameid}"
  },
  "Moderation": {
    "ClearSpecialAlertUsers": [

    ]
  },
  "OpenAI": {
    "BaseUrl": "https://api.openai.com/v1/",
    "ApiKey": "",
    "Model": "gpt-4o-mini",
    "DefaultAlertTone": "hype",
    "DefaultAlertMaxWords": 14,
    "WatchStreakThreshold": 20,
    "GiftSubThreshold": 5
  },
  "AlertSettings": {
    "AlertTimeOut": 60,
    "AcknowledgeTimeOut": 10,
    "MaxQueueSize": 50,
    "MaxOfflineQueueTime": 60,
    "RetryTaskDelay": 500
  }
}